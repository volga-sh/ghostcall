{
	"name": "@volga-sh/evm-ghostcall",
	"version": "0.0.1",
	"description": "Zero-deployment batching program and TypeScript SDK for CREATE-style eth_call requests.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/volga-sh/ghostcall.git"
	},
	"bugs": {
		"url": "https://github.com/volga-sh/ghostcall/issues"
	},
	"homepage": "https://ghostcall.volga.sh",
	"main": "./dist/sdk/index.js",
	"types": "./dist/sdk/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/sdk/index.d.ts",
			"import": "./dist/sdk/index.js"
		}
	},
	"files": [
		"dist/",
		"src/Ghostcall.yul"
	],
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"benchmark:limits": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/benchmark-limits.ts",
		"build:contracts": "forge build && npm run generate:sdk:initcode",
		"build:sdk": "npm run build:contracts && tsc --project tsconfig.build.json",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"docs:build": "npm run build --prefix docs",
		"docs:dev": "npm run dev --prefix docs",
		"docs:preview": "npm run preview --prefix docs",
		"check:sdk:initcode": "git diff --exit-code -- src/sdk/generated/initcode.ts",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"generate:sdk:initcode": "node scripts/generate-sdk-initcode.mjs",
		"lint": "biome lint .",
		"lint:fix": "npm run check:fix",
		"prepack": "npm run build:sdk",
		"test": "npm run build:contracts && node --disable-warning=ExperimentalWarning --experimental-strip-types --test test/*.test.ts",
		"test:watch": "node --disable-warning=ExperimentalWarning --experimental-strip-types --test --watch test/*.test.ts",
		"typecheck": "tsc --project tsconfig.json"
	},
	"dependencies": {},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@safe-global/mock-contract": "4.1.0",
		"ox": "0.9.6",
		"@types/node": "24.3.1",
		"typescript": "5.9.2"
	}
}
